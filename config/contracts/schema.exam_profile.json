    "nome_exame": { "type": "string" },
    "slug": { "type": "string" },
    "contract_version": { "type": "string" },
    "equipment_id": { "type": "string" },
    "targets": { "type": "array", "items": { "type": "string" } },
    "target_aliases": { "type": "object" },
